{
  "entities": {
    "ProgressLog": {
      "title": "ProgressLog",
      "description": "User progress measurements",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "weight": { "type": "number" },
        "chest": { "type": "number" },
        "waist": { "type": "number" },
        "arms": { "type": "number", "description": "Optional" },
        "legs": { "type": "number", "description": "Optional" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "weight", "date", "createdAt"]
    },
    "WorkoutCategory": {
      "title": "WorkoutCategory",
      "description": "Workout categories/plans",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "count": { "type": "number" },
        "image": { "type": "string" }
      },
      "required": ["title", "count", "image"]
    },
    "Exercise": {
      "title": "Exercise",
      "description": "Exercises for a workout category",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "sets": { "type": "number" },
        "reps": { "type": "string" },
        "rest": { "type": "number" },
        "target": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["categoryId", "name", "sets", "reps", "rest", "target", "image"]
    },
    "NutritionPlan": {
      "title": "NutritionPlan",
      "description": "Nutrition Plans",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "cals": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["title", "cals", "image"]
    },
    "WorkoutLog": {
      "title": "WorkoutLog",
      "description": "Log of a fully completed workout session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "categoryId": { "type": "string" },
        "date": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "categoryId", "date", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}/progressLogs/{logId}": {
      "schema": { "$ref": "#/entities/ProgressLog" },
      "description": "Collection inside user doc for their progress tracking logs."
    },
    "users/{userId}/workoutLogs/{logId}": {
      "schema": { "$ref": "#/entities/WorkoutLog" },
      "description": "Collection inside user doc for completed workouts."
    },
    "workoutCategories/{categoryId}": {
      "schema": { "$ref": "#/entities/WorkoutCategory" },
      "description": "Global read-only collection for workout categories."
    },
    "exercises/{exerciseId}": {
      "schema": { "$ref": "#/entities/Exercise" },
      "description": "Global read-only collection for exercises."
    },
    "nutritionPlans/{planId}": {
      "schema": { "$ref": "#/entities/NutritionPlan" },
      "description": "Global read-only collection for nutrition plans."
    }
  }
}
