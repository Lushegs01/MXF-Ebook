rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidProgressLog(data, userId) {
      return data.keys().hasAll(['userId', 'weight', 'date', 'createdAt'])
        && data.keys().size() <= 8
        && data.userId == userId
        && data.weight is number
        && data.date is string && data.date.size() <= 20
        && data.createdAt == request.time
        && (!('chest' in data) || data.chest is number)
        && (!('waist' in data) || data.waist is number)
        && (!('arms' in data) || data.arms is number)
        && (!('legs' in data) || data.legs is number);
    }

    function isValidWorkoutLog(data, userId) {
      return data.keys().hasAll(['userId', 'categoryId', 'date', 'durationMinutes', 'createdAt'])
        && data.keys().size() == 5
        && data.userId == userId
        && data.categoryId is string && data.categoryId.size() <= 128
        && data.date is string && data.date.size() <= 20
        && data.durationMinutes is number
        && data.createdAt == request.time;
    }

    function isValidWorkoutCategory(data) {
      return data.keys().hasAll(['title', 'count', 'image'])
        && data.keys().size() == 3
        && data.title is string && data.title.size() <= 200
        && data.count is number
        && data.image is string && data.image.size() <= 1000;
    }

    function isValidExercise(data) {
      return data.keys().hasAll(['categoryId', 'name', 'sets', 'reps', 'rest', 'target', 'image'])
        && data.keys().size() == 7
        && data.categoryId is string && data.categoryId.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.sets is number
        && data.reps is string && data.reps.size() <= 50
        && data.rest is number
        && data.target is string && data.target.size() <= 200
        && data.image is string && data.image.size() <= 1000;
    }

    function isValidNutritionPlan(data) {
      return data.keys().hasAll(['title', 'cals', 'image'])
        && data.keys().size() == 3
        && data.title is string && data.title.size() <= 200
        && data.cals is string && data.cals.size() <= 50
        && data.image is string && data.image.size() <= 1000;
    }

    match /users/{userId}/progressLogs/{logId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(logId);
      allow list: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(logId)
        && isValidProgressLog(incoming(), userId);
      allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(logId);
    }
    
    match /users/{userId}/workoutLogs/{logId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(logId);
      allow list: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(logId)
        && isValidWorkoutLog(incoming(), userId);
    }

    match /workoutCategories/{categoryId} {
      allow get: if isSignedIn() && isValidId(categoryId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(categoryId) && isValidWorkoutCategory(incoming());
      allow update: if isSignedIn() && isValidId(categoryId) && isValidWorkoutCategory(incoming());
    }

    match /exercises/{exerciseId} {
      allow get: if isSignedIn() && isValidId(exerciseId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(exerciseId) && isValidExercise(incoming());
      allow update: if isSignedIn() && isValidId(exerciseId) && isValidExercise(incoming());
    }

    match /nutritionPlans/{planId} {
      allow get: if isSignedIn() && isValidId(planId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(planId) && isValidNutritionPlan(incoming());
      allow update: if isSignedIn() && isValidId(planId) && isValidNutritionPlan(incoming());
    }
  }
}
