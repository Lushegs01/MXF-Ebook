rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidProgressLog(data, userId) {
      return data.keys().hasAll(['userId', 'weight', 'date', 'createdAt'])
        && data.keys().size() <= 8
        && data.userId == userId
        && data.weight is number
        && data.date is string && data.date.size() <= 20
        && data.createdAt == request.time
        && (!('chest' in data) || data.chest is number)
        && (!('waist' in data) || data.waist is number)
        && (!('arms' in data) || data.arms is number)
        && (!('legs' in data) || data.legs is number);
    }

    function isValidWorkoutSession(data, userId) {
      return data.keys().hasAll(['userId', 'workoutId', 'workoutTitle', 'completedAt', 'createdAt'])
        && data.keys().size() <= 8
        && data.userId == userId
        && data.workoutId is string && data.workoutId.size() <= 64
        && data.workoutTitle is string && data.workoutTitle.size() <= 100
        && data.completedAt is string && data.completedAt.size() <= 20
        && data.createdAt == request.time
        && (!('durationMin' in data) || data.durationMin is number)
        && (!('exerciseCount' in data) || data.exerciseCount is number);
    }

    function isValidUserProfile(data) {
      return data.keys().size() <= 5
        && (!('isPremium' in data) || data.isPremium is bool)
        && (!('goalWeight' in data) || data.goalWeight == null || data.goalWeight is number)
        && (!('notificationsEnabled' in data) || data.notificationsEnabled is bool)
        && (!('updatedAt' in data) || data.updatedAt == request.time);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create, update: if isSignedIn() && request.auth.uid == userId && isValidId(userId)
        && isValidUserProfile(incoming());
    }

    match /users/{userId}/progressLogs/{logId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(logId);
      allow list: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(logId)
        && isValidProgressLog(incoming(), userId);
      allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(logId);
    }

    match /users/{userId}/workoutSessions/{sessionId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(sessionId);
      allow list: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(sessionId)
        && isValidWorkoutSession(incoming(), userId);
      allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(sessionId);
    }
  }
}
